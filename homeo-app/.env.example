# ================================================================
# Doctor Follow-Up Medical App — Environment Variables
# Copy this file to .env.local and fill in your values
# ================================================================

# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Server-side only, never expose

# ── Anthropic Claude ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...  # For Report Analyzer, Pre-Visit Brief, Gut Tags AI

# ── Twilio WhatsApp Business ─────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886    # Twilio sandbox number
TWILIO_WHATSAPP_TEMPLATE_SID=HXxxxxxxxxxxxxxxx  # Approved message template

# ── Upstash Redis (Cache + Cron jobs) ────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Expo / Push Notifications ────────────────────────────────────
# (For Expo managed workflow — use in mobile app)
EXPO_ACCESS_TOKEN=your-expo-access-token
FCM_SERVER_KEY=your-fcm-server-key              # Firebase Cloud Messaging
APNS_KEY_ID=your-apns-key-id                    # Apple Push Notification Service
APNS_TEAM_ID=your-apple-team-id

# ── Next.js ──────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret             # Random string, min 32 chars
NEXTAUTH_URL=http://localhost:3000               # Production: your domain

# ── App Config ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="FollowUp Care"
NEXT_PUBLIC_DEMO_MODE=true   # Set false in production to disable demo shortcuts

# ── Twilio (for real SMS OTP) ────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SID=your_twilio_verify_sid
